# Copy this to .env and fill in. .env is gitignored.

# --- Model providers (you don't need all of them) ---
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
DEEPSEEK_API_KEY=sk-...
OPENAI_API_KEY=sk-...

# --- Zotero ---
# Get from https://www.zotero.org/settings/keys
ZOTERO_USER_ID=1234567
ZOTERO_API_KEY=...

# --- External paper discovery (all optional) ---
# OpenAlex: no key required (used by default in discover.py).
# Semantic Scholar: optional. Increases rate limit. https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
# Elicit: requires a paid plan. https://elicit.com/
ELICIT_API_KEY=

# --- Paths (defaults shown; uncomment + edit only if you need custom locations) ---
# THESIS_ROOT=~/thesis
# ZOTERO_STORAGE=~/Zotero/storage

# --- Local + CLI-routed models (all optional) ---
# Local Ollama model used by the `local` alias (LiteLLM-managed).
# OLLAMA_MODEL=ollama/llama3.3

# CLI-routed aliases: the prompt is appended as the final argv element.
# Defaults shown — uncomment + edit if your CLI uses different flags.
# CLAUDE_CLI_CMD="claude -p"
# GEMINI_CLI_CMD="gemini -p"
# CODEX_CLI_CMD="codex exec"
# OLLAMA_CLI_CMD="ollama run llama3.3"
# CLI_TIMEOUT=600   # seconds before a CLI call is killed

# --- Editor used by ./paraphrase.py --interactive ---
# EDITOR=nvim
