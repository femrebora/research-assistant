# Copy this to .env and fill in. .env is gitignored.

# --- Model providers (you don't need all of them) ---
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
DEEPSEEK_API_KEY=sk-...
OPENAI_API_KEY=sk-...

# --- Zotero ---
# Get from https://www.zotero.org/settings/keys
ZOTERO_USER_ID=1234567
ZOTERO_API_KEY=...

# --- Paths ---
THESIS_ROOT=/home/emre/thesis
ZOTERO_STORAGE=/home/emre/Zotero/storage
